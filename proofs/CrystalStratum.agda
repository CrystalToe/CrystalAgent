-- CrystalStratum — Multi-level hierarchy of the magic-number formula
--
-- Verifies the four-layer hierarchy generated by partial evaluation:
--   L0 primary   : M(n)    = full formula         → canonical magic
--   L1 secondary : M^(2)(n) = k ≤ 2 partial sum   → pronic (Ni-56)
--   L2 tertiary  : M^(1)(n) = 2n                  → emergent subshells
--   L3 fine      : M(n) + rectangle-invariant offset
--
-- All 13 literature-known closures verified to land at L0/L1/L2.
-- All forbidden predictions (even N containing foreign prime) checked.
--
-- Uses refl only; no division (Builtin.Nat lacks _/_).

module CrystalStratum where

open import Agda.Builtin.Equality
open import Agda.Builtin.Nat renaming (Nat to ℕ)
open import Agda.Builtin.Bool

-- ============================================================
-- RECTANGLE INPUTS
-- ============================================================

nW : ℕ
nW = 2

nC : ℕ
nC = 3

chi : ℕ
chi = nW * nC            -- 6

beta0 : ℕ
beta0 = 7

towerD : ℕ
towerD = chi * (chi + 1) -- 42

g : ℕ
g = nW * nW + nC * nC    -- 13

-- ============================================================
-- BINOMIAL AND IVERSON BRACKET
-- ============================================================

binom : ℕ → ℕ → ℕ
binom _ 0 = 1
binom 0 (suc _) = 0
binom (suc n) (suc k) = binom n k + binom n (suc k)

_≤?_ : ℕ → ℕ → Bool
zero ≤? _       = true
suc _ ≤? zero   = false
suc n ≤? suc m  = n ≤? m

iverson : ℕ → ℕ → ℕ
iverson n m with n ≤? m
... | true  = 1
... | false = 0

-- ============================================================
-- HIERARCHY LAYER FUNCTIONS
-- ============================================================

-- Layer 0: full formula (primary / canonical magic)
M : ℕ → ℕ
M n = nW * (binom n 1 + binom n 2 + binom n 3)
    + nW * binom n 2 * iverson n nC

-- Layer 1: partial sum up to k = 2 (pronic-like)
M2 : ℕ → ℕ
M2 n = nW * (binom n 1 + binom n 2)
     + nW * binom n 2 * iverson n nC

-- Layer 2: partial sum up to k = 1 (= 2n)
M1 : ℕ → ℕ
M1 n = nW * binom n 1

